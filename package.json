{
	"name": "@storyio/cli",
	"version": "0.1.0",
	"license": "MIT",
	"type": "module",
	"bin": {
		"story": "./dist/cli.js"
	},
	"scripts": {
		"dev": "tsup --watch",
		"build": "tsup",
		"build:vogon": "tsup --config tsup.config.ts --entry.vogon src/bin/vogon.ts",
		"test": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --project unit --coverage",
		"test:integration": "vitest run --project integration",
		"test:e2e": "vitest run --project e2e",
		"test:e2e:keep": "STORY_E2E_KEEP_REPOS=1 vitest run --project e2e",
		"test:all": "vitest run",
		"lint": "biome check ../../",
		"fmt": "biome format --write ../../",
		"type-check": "tsc --noEmit -p tsconfig.check.json"
	},
	"dependencies": {
		"@clack/prompts": "^0.9",
		"@secretlint/core": "^11.7.1",
		"@secretlint/secretlint-rule-preset-recommend": "^11.7.1",
		"cac": "^6",
		"diff-match-patch": "^1.0.5",
		"execa": "^9.6.1",
		"isomorphic-git": "^1.37.5",
		"ms": "^2.1.3",
		"picocolors": "^1",
		"secretlint": "^11.7.1",
		"ts-pattern": "^5.9.0",
		"tsup": "^8.5.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@secretlint/types": "^11.7.1",
		"@types/bun": "latest",
		"@types/diff-match-patch": "^1.0.36",
		"@vitest/coverage-v8": "^3",
		"bun-types": "1.3.13",
		"typescript": "^5",
		"vitest": "^3"
	}
}