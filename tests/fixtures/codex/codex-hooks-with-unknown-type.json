{
	"$schema": "https://example.com/codex-hooks.schema.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "^Bash$",
				"hooks": [{ "type": "command", "command": "my-custom-hook" }]
			}
		],
		"UnknownEventType": [
			{
				"matcher": null,
				"hooks": [{ "type": "command", "command": "preserve-me" }]
			}
		]
	}
}
